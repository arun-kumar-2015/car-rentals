/**
 * Firestore Security Rules for Arun Car Rentals
 *
 * CORE PHILOSOPHY:
 * This ruleset implements a Hybrid Administrative model. It provides public visibility for
 * product listings (Cars) while centralizing management and sensitive data (Bookings) 
 * under a Database-Based Access Control (DBAC) admin system.
 *
 * DATA STRUCTURE:
 * - /cars/{carId}: Publicly readable car catalog. Admin-only writes.
 * - /bookings/{bookingId}: Transactional collection for rental requests. Open for creation, 
 *   but management (read/update/delete) is restricted to admins due to a lack of user 
 *   ownership fields in the current schema.
 * - /roles_admin/{adminId}: A registry of administrative UIDs.
 *
 * KEY SECURITY DECISIONS:
 * - Admin Identification: Uses the "existence over content" principle. If a document 
 *   matching a user's UID exists in /roles_admin, they are granted global admin privileges.
 * - Anonymous Access: Supports anonymous car browsing and booking creation to reduce 
 *   friction in the rental funnel.
 * - Ownership Limitations: Because the Booking entity lacks a 'creatorUserId', 
 *   standard user-ownership rules (P3.1) cannot be applied. All booking management 
 *   is defaulted to Admins to prevent unauthorized data exposure.
 *
 * PROTOTYPING MODE NOTICE:
 * These rules prioritize strict authorization (who can access) over strict schema 
 * validation (what is written). This allows for rapid UI/UX iteration.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    /** 
     * @description Checks if the user is authenticated with Firebase Auth.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * @description Checks if the authenticated user's UID exists in the admin roles collection.
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** 
     * @description Combines authentication, admin status, and document existence for write operations.
     */
    function isExistingAdmin() {
      return isAdmin() && resource != null;
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the Car catalog. Publicly viewable, admin managed.
     * @path /cars/{carId}
     * @allow get, list: (any user)
     * @allow create, update, delete: (authenticated admin)
     * @deny write: (non-admin user)
     * @principle Public Read with Owner-Only Writes (Admin variant).
     */
    match /cars/{carId} {
      allow get, list: if true;
      allow create: if isAdmin();
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Rules for Rental Bookings. Open creation for customers; Admin-only management.
     * @path /bookings/{bookingId}
     * @allow create: (any user/anonymous) to support low-friction booking.
     * @allow get, list, update, delete: (authenticated admin).
     * @deny get, list: (regular users) due to lack of ownership field in schema.
     * @principle Open creation with privileged management.
     */
    match /bookings/{bookingId} {
      allow get, list: if isAdmin();
      // Open create allowed per IR requirements for anonymous/all-user booking flow.
      allow create: if request.resource.data.id == bookingId; 
      allow update, delete: if isExistingAdmin();
    }

    /**
     * @description Registry of Admin UIDs. Used for DBAC authorization checks.
     * @path /roles_admin/{adminId}
     * @allow get: (authenticated users) to allow the app to check its own admin status.
     * @allow list: (authenticated admin).
     * @deny create, update, delete: (all) should be managed via Firebase Console or Admin SDK.
     * @principle Database-Based Access Control (DBAC).
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; 
    }
  }
}